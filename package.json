{
  "name": "deductible-tracker",
  "private": true,
  "type": "module",
  "scripts": {
    "test:js": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
    "tailwind:build": "tailwindcss -i ./static/css/input.css -o ./public/assets/tailwind.css --minify",
    "tailwind:watch": "tailwindcss -i ./static/css/input.css -o ./public/assets/tailwind.css --watch",
    "lint:js": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.2.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.0"
  }
}
